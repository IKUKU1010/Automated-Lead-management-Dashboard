# ─── DATABASE ────────────────────────────────────────────────────────────────
# Local dev: leave as default (creates leads.db in project root)
# Railway:   set to /data/leads.db (mounted volume)
DATABASE_PATH=./leads.db

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── AI (OPENROUTER) ─────────────────────────────────────────────────────────
# Leave empty for prototype mode — uses rule-based responses
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── ARBOSTAR CRM ────────────────────────────────────────────────────────────
# Company Management → API Access in ArboStar dashboard
# Leave empty for prototype mode — syncs are simulated/logged only
ARBOSTAR_COMPANY_ID=
ARBOSTAR_API_KEY=

# ─── EMAIL (SENDGRID) ────────────────────────────────────────────────────────
# Leave empty for prototype mode — emails are logged only
# Get key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
FROM_EMAIL=customerservice@premiertreesllc.com

# ─── SMS (AGENT PHONE) ───────────────────────────────────────────────────────
# Leave empty for prototype mode
AGENT_PHONE_API_KEY=
AGENT_PHONE_NUMBER=

# ─── EMAIL FORWARDING ────────────────────────────────────────────────────────
# The inbox that receives forwarded LSA + AnswerForce emails
EMAIL_FORWARD_ADDRESS=
