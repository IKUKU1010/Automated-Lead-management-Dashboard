# ─────────────────────────────────────────────────────────────────────────────
# .env.railway — Railway environment variable template
#
# DO NOT put real secrets here. This file is committed to Git as a reference.
# Set actual values in Railway dashboard → your service → Variables tab,
# OR run:  railway variables set KEY=value
# OR bulk-import with: railway variables import .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Must point to Railway's persistent volume mount path.
# In Railway dashboard: add a Volume, mount it at /data, then set this:
DATABASE_PATH=/data/leads.db

# ─── SERVER ──────────────────────────────────────────────────────────────────
# PORT is auto-set by Railway — do NOT override it here.
# Just make sure your code reads: Number(process.env.PORT ?? 3000)  ← already done
NODE_ENV=production

# ─── AI (OPENROUTER) ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here

# ─── ARBOSTAR CRM ────────────────────────────────────────────────────────────
ARBOSTAR_COMPANY_ID=your_company_id_here
ARBOSTAR_API_KEY=your_arbostar_key_here

# ─── EMAIL (SENDGRID) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_key_here
FROM_EMAIL=customerservice@premiertreesllc.com

# ─── SMS (AGENT PHONE) ───────────────────────────────────────────────────────
AGENT_PHONE_API_KEY=your_agent_phone_key_here
AGENT_PHONE_NUMBER=+12165550000

# ─── EMAIL FORWARDING ────────────────────────────────────────────────────────
EMAIL_FORWARD_ADDRESS=leads@premiertreesllc.com
